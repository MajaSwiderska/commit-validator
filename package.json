{
    "name": "commit-validator",
    "version": "1.0.0",
    "description": "Pre-commit hook that catches typos in git commit messages",
    "main": "src/spellcheck.js",
    "bin": {
        "commit-validator": "./bin/cli.js"
    },
    "scripts": {
    "test": "node test/test.js",
    "demo": "node demo/demo.js",
    "install-hook": "chmod +x scripts/install.sh && ./scripts/install.sh",
    "uninstall": "chmod +x scripts/uninstall.sh && ./scripts/uninstall.sh",
    "global-install": "npm link",
    "dev": "node bin/cli.js"
    },
    "keywords": ["git", "hook", "commit", "typo", "validator"],
    "author": "Maja Swiderska"
}